# Copia este archivo como .streamlit/secrets.toml para probar en local.
# En Streamlit Community Cloud, coloca estos mismos valores en App settings > Secrets.

google_sheet_id = "ID_DE_TU_GOOGLE_SHEET"
google_worksheet = "ranking"

[gcp_service_account]
type = "service_account"
project_id = "TU_PROJECT_ID"
private_key_id = "TU_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
client_email = "tu-service-account@tu-proyecto.iam.gserviceaccount.com"
client_id = "TU_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "TU_CLIENT_CERT_URL"
